      "id": "edit-fields",
      "name": "Edit Fields - Extract Stats",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "// Tính engagement rate\nconst data = $input.first().json;\n\nconst views = data.views || 0;\nconst likes = data.likes || 0;\nconst comments = data.comments || 0;\nconst shares = data.shares || 0;\nconst saves = data.saves || 0;\n\nlet engagement_rate = 0;\nif (views > 0) {\n    const total_engagement = likes + comments + shares + saves;\n    engagement_rate = Math.round((total_engagement / views) * 10000) / 100;\n}\n\nreturn {\n    ...data,\n    engagement_rate: engagement_rate,\n    total_engagement: likes + comments + shares + saves\n};"
      },
