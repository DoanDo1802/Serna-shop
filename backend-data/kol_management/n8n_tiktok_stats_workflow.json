      "name": "HTTP Request - Get TikTok HTML",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// Lấy dữ liệu từ input\nconst inputData = $input.first().json;\nconst htmlContent = inputData.data || \"\";\nconst setCookieHeader = inputData.headers['set-cookie'];\n\n// Xử lý gộp Cookie thành chuỗi\nlet cookieString = \"\";\nif (Array.isArray(setCookieHeader)) {\n    cookieString = setCookieHeader.join(\"; \");\n} else if (typeof setCookieHeader === 'string') {\n    cookieString = setCookieHeader;\n}\n\n// Trích xuất JSON từ thẻ __UNIVERSAL_DATA_FOR_REHYDRATION__\nlet extractedJson = {};\nconst regex = /<script [^>]*id=\"__UNIVERSAL_DATA_FOR_REHYDRATION__\"[^>]*>([\\s\\S]*?)<\\/script>/i;\nconst match = htmlContent.match(regex);\n\nif (match && match[1]) {\n    try {\n        extractedJson = JSON.parse(match[1].trim());\n    } catch (e) {\n        extractedJson = { error: \"Không thể parse JSON từ HTML\" };\n    }\n} else {\n    extractedJson = { error: \"Không tìm thấy __UNIVERSAL_DATA_FOR_REHYDRATION__\" };\n}\n\n// Trả về kết quả\nreturn {\n    data: {\n        ...extractedJson,\n        cookie: cookieString\n    }\n};"
      },
      "id": "code-parse-json",
      "name": "Code - Parse JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
